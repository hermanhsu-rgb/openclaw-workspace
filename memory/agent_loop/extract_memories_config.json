{
  "name": "extract-memories",
  "version": "1.0.0",
  "description": "OpenClaw Extract Memories - 基于 Claude Code 架构",
  "enabled": true,
  "extraction": {
    "schedule": "0 */4 * * *",
    "batch_size": 50,
    "min_confidence": 0.6,
    "extract_types": ["facts", "preferences", "decisions", "tasks", "relationships", "patterns"]
  },
  "memory_types": {
    "facts": {
      "description": "客观事实和信息",
      "examples": ["用户喜欢使用 Tavily 搜索", "系统配置在 ~/.openclaw"],
      "priority": "high",
      "retention": "permanent"
    },
    "preferences": {
      "description": "用户偏好和习惯",
      "examples": ["用户偏好免费工具", "用户喜欢简洁的界面"],
      "priority": "high",
      "retention": "long_term"
    },
    "decisions": {
      "description": "决策和选择记录",
      "examples": ["选择使用 ntfy 而不是企业微信", "决定每天 3:00 自动更新"],
      "priority": "medium",
      "retention": "long_term"
    },
    "tasks": {
      "description": "待办事项和任务",
      "examples": ["需要配置 GitHub 推送", "计划升级 Agent Loop"],
      "priority": "high",
      "retention": "until_completed"
    },
    "relationships": {
      "description": "实体间关系",
      "examples": ["skills 依赖于 agent_loop", "定时任务使用 crontab"],
      "priority": "medium",
      "retention": "long_term"
    },
    "patterns": {
      "description": "行为模式和规律",
      "examples": ["用户经常在晚上工作", "升级前先备份"],
      "priority": "low",
      "retention": "medium_term"
    }
  },
  "extraction_rules": {
    "key_indicators": [
      "喜欢", "偏好", "习惯", "总是", "从不", "重要", "关键",
      "决定", "选择", "计划", "需要", "必须", "应该",
      "记住", "记录", "保存", "备份",
      "妻子", "孩子", "家庭", "工作", "项目"
    ],
    "context_window": 3,
    "merge_similar": true,
    "similarity_threshold": 0.85
  },
  "storage": {
    "format": "markdown",
    "location": "~/.openclaw/workspace/memory/extracted",
    "indexing": true,
    "compression": false
  },
  "llm_prompts": {
    "extract": "从以下对话中提取关键记忆:\n\n对话内容:\n{content}\n\n请提取以下类型的信息:\n1. 事实 (Facts) - 客观信息\n2. 偏好 (Preferences) - 用户喜好\n3. 决策 (Decisions) - 做出的选择\n4. 任务 (Tasks) - 待办事项\n5. 关系 (Relationships) - 实体关联\n\n以 JSON 格式返回提取结果:\n{\n  \"memories\": [\n    {\n      \"type\": \"fact|preference|decision|task|relationship\",\n      \"content\": \"提取的内容\",\n      \"confidence\": 0.0-1.0,\n      \"context\": \"原始上下文\"\n    }\n  ]\n}",
    "summarize": "总结以下记忆:\n\n记忆列表:\n{memories}\n\n请生成简洁的总结，保留最重要的信息。"
  },
  "cleanup": {
    "enabled": true,
    "deduplicate_interval_days": 7,
    "archive_after_days": 90,
    "delete_after_days": 365
  }
}
